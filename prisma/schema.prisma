// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String    @id @default(cuid())  
  firstname   String    @db.VarChar(100)
  lastname    String?   @db.VarChar(100)
  email       String    @unique @db.VarChar(100)
  phoneNumber String    @unique @db.VarChar(20)
  password    String    @db.VarChar(100)
  token       String?   @db.VarChar(100)    
  role        Role  
  createdAt   DateTime  @default(now())

  roomsAsCustomer RoomChat[] @relation("CustomerRooms")
  roomsAsTailor   RoomChat[] @relation("TailorRooms")
  tailorProfile   TailorProfile? 
  givenReviews   RatingReview[] @relation("CustomerReviews")
  receivedReviews RatingReview[] @relation("TailorReviews")
  ordersAsTailor   Order[] @relation("TailorOrders")
  ordersAsCustomer Order[] @relation("CustomerOrders")

  @@map("User")
}

model TailorProfile {
  id                String    @id @default(cuid())  
  userId            String    @unique
  provinceId        String
  regencyId         String
  districtId        String
  villageId         String
  addressDetail     String
  workEstimation    String
  priceRange        String
  specialization    String[]
  businessDescription String
  profilePicture    String?
  certificate       String[]
  averageRating     Float      @default(0.0)

  user              User        @relation(fields: [userId], references: [id])
  province          Province    @relation("ProvinceTailors", fields: [provinceId], references: [code])
  regency           Regency     @relation("RegencyTailors", fields: [regencyId], references: [code])
  district          District    @relation("DistrictTailors", fields: [districtId], references: [code])
  village           Village     @relation("VillageTailors", fields: [villageId], references: [code])
  article           Article[]   @relation("TailorArticles")
  courses           Course[]    @relation("TailorCourses")

  @@map("TailorProfile")
}

model RoomChat {
  id         String   @id @default(cuid())  
  customerId String
  tailorId   String
  createdAt  DateTime @default(now())

  customer   User @relation("CustomerRooms", fields: [customerId], references: [id])
  tailor     User @relation("TailorRooms", fields: [tailorId], references: [id])

  chats      Chat[]
  Order      Order[]

  latestMessage      String?    
  latestMessageTime  DateTime?  
  unreadCountCustomer Int @default(0)  
  unreadCountTailor   Int @default(0)  

  @@unique([customerId, tailorId])
}

model Chat {
  id         String   @id @default(cuid())  
  roomId     String
  room       RoomChat @relation(fields: [roomId], references: [id])

  senderId   String
  senderType Role 
  message    String
  type       String   @default("text") 
  createdAt  DateTime @default(now())
}

model RatingReview {
  id        String   @id @default(cuid())  
  rating    Int      @db.SmallInt  
  review    String?   @db.VarChar(100)
  tailorId  String
  customerId String
  image     String?
  createdAt DateTime @default(now())
  tailor    User   @relation("TailorReviews", fields: [tailorId], references: [id], onDelete: Cascade)
  customer  User   @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)

  @@map("RatingReview")
}

model Province {
  code      String       @id @unique
  name      String
  regencies Regency[]    
  tailors   TailorProfile[]     @relation("ProvinceTailors") 
}

model Regency {
  code            String      @id @unique
  name            String
  province_code   String      
  province        Province    @relation(fields: [province_code], references: [code]) 
  districts       District[]  
  tailors         TailorProfile[]    @relation("RegencyTailors") 
}

model District {
  code            String      @id @unique
  name            String
  regency_code    String      
  regency         Regency     @relation(fields: [regency_code], references: [code]) 
  villages        Village[]  
  tailors         TailorProfile[]    @relation("DistrictTailors") 
}

model Village {
  code            String      @id @unique
  name            String
  district_code   String     
  district        District    @relation(fields: [district_code], references: [code]) 
  tailors         TailorProfile[]    @relation("VillageTailors") 
}

model Order {
  id           String       @id @default(cuid())
  tailorId     String
  customerId   String
  roomId       String
  customerName String
  totalPrice   Int
  status       OrderStatus  @default(NOT_YET_PAY)
  orderDate    DateTime     @default(now())
  bankName        String
  bankAccountOwner  String
  bankAccountNumber String
  deliveryServiceName String?
  receiptNumber String?
  deliveryImage String?
  paymentImage String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  room         RoomChat @relation(fields: [roomId], references: [id])
  tailor       User @relation("TailorOrders", fields: [tailorId], references: [id])
  customer     User @relation("CustomerOrders", fields: [customerId], references: [id])

  orderItems   OrderItem[]  
}

model OrderItem {
  id       String  @id @default(cuid())
  orderId  String
  name     String
  qty      Int
  price    Int

  order    Order  @relation(fields: [orderId], references: [id])
}

model Article {
  id           String       @id @default(cuid())
  tailorId     String
  authorName   String
  imageUrl     String?
  title        String
  content      String

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  tailor       TailorProfile @relation("TailorArticles", fields: [tailorId], references: [userId])
}

model Course {
  id           String       @id @default(cuid())
  tailorId     String
  authorName   String
  imageUrl     String
  courseName   String
  shortDescription      String
  registrationLink      String
  description  String

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  tailor       TailorProfile @relation("TailorCourses", fields: [tailorId], references: [userId])
}

enum OrderStatus {
  NOT_YET_PAY
  ON_PROCCESS
  DONE
}

enum Role {
  CUSTOMER
  TAILOR
}


