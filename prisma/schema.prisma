model Order {
  id           String    @id @default(cuid()) 
  tailorId     String     
  customerId   String     
  roomId       String?    
  orderType    OrderType @default(PICKUP)
  totalPrice   Int
  status       OrderStatus @default(NOT_YET_PAY)
  orderDate    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  room         RoomChat? @relation(fields: [roomId], references: [id], onDelete: SetNull)
  tailor       User @relation("TailorOrders", fields: [tailorId], references: [id])
  customer     User @relation("CustomerOrders", fields: [customerId], references: [id])
  orderItems   OrderItem[]
  orderShipping      OrderShipping?
  orderCancellation  OrderCancellation?
}

model OrderShipping {
  id                  String   @id @default(cuid())  
  orderId             String   @unique  
  deliveryAddress     String? 
  deliveryServiceName String?  @db.VarChar(255)
  receiptNumber       String?  @db.VarChar(255)
  deliveryImage       String? 

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderCancellation {
  id                         String   @id @default(cuid()) 
  orderId                    String   @unique 
  cancellationReason         String?  @db.VarChar(255)
  cancelledAt                DateTime?
  cancellationRequestImage   String?  
  cancellationRejectedReason String?  @db.VarChar(255)
  isCancellationApproved     Boolean?
  previousStatus             OrderStatus?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}


model OrderItem {
  id       String  @id @default(cuid()) 
  orderId  String
  name     String @db.VarChar(255)
  qty      Int
  price    Int

  order    Order  @relation(fields: [orderId], references: [id])
}

model Article {
  id           String       @id @default(cuid())  
  tailorId     String       
  imageUrl     String?
  title        String       @db.VarChar(255)
  content      String

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  tailor       TailorProfile @relation("TailorArticles", fields: [tailorId], references: [userId])
}

model Course {
  id           String       @id @default(cuid())  
  tailorId     String       
  imageUrl     String         
  courseName   String       @db.VarChar(255)
  shortDescription      String    @db.VarChar(500)
  registrationLink      String
  description  String
  place        String?      
  courseDate   String?      @db.VarChar(255)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  tailor       TailorProfile @relation("TailorCourses", fields: [tailorId], references: [userId])
}

model Stuff {
  id           String       @id @default(cuid())  
  tailorId     String       
  name         String       @db.VarChar(255)
  imageUrl        String    
  stuffCaetgory   StuffCategory
  price           Int

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  tailor          TailorProfile @relation("TailorStuffs", fields: [tailorId], references: [userId])
}

