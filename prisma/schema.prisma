enum OrderStatus {
  NOT_YET_PAY
  ADMIN_REVIEWING_CANCELLATION
  ON_PROCCESS
  TAILOR_SENT_PRODUCT
  WAITING_CUSTOMER_RECEIVE_CONFIRMATION
  DONE
  CANCELED
}

enum Role {
  CUSTOMER
  TAILOR
  ADMIN
}

enum StuffCategory {
  FABRIC
  ACCECORIES
}

enum OrderType {
  DELIVERY
  PICKUP
}

enum Gender {
  MALE
  FEMALE
}

