// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id          Int      @id @default(autoincrement()) // ID unik yang auto-increment
  firstname   String   @db.VarChar(100)             // Nama depan
  lastname    String?  @db.VarChar(100)             // Nama belakang
  email       String   @unique @db.VarChar(100)     // Email unik
  phoneNumber String   @db.VarChar(20)              // Nomor telepon
  password    String   @db.VarChar(100)             // Password
  token       String?  @db.VarChar(100)             // Token (opsional)
  ratings     RatingReview[]
  roomsAsCustomer RoomChat[] @relation("CustomerRooms")

  @@map("Customer") // Pemetaan ke tabel "customers" di database
}

model Province {
  code      String       @id @unique
  name      String
  regencies Regency[]    // Relasi satu-ke-banyak ke Regency
  tailors   Tailor[]     @relation("ProvinceTailors") // Relasi dua arah ke Tailor
}

model Regency {
  code            String      @id @unique
  name            String
  province_code   String      // Menghubungkan dengan `code` dari Province
  province        Province    @relation(fields: [province_code], references: [code]) // Menghubungkan ke Province
  districts       District[]  // Relasi satu-ke-banyak ke District
  tailors         Tailor[]    @relation("RegencyTailors") // Relasi dua arah ke Tailor
}

model District {
  code            String      @id @unique
  name            String
  regency_code    String      // Menghubungkan dengan `code` dari Regency
  regency         Regency     @relation(fields: [regency_code], references: [code]) // Menghubungkan ke Regency
  villages        Village[]   // Relasi satu-ke-banyak ke Village
  tailors         Tailor[]    @relation("DistrictTailors") // Relasi dua arah ke Tailor
}

model Village {
  code            String      @id @unique
  name            String
  district_code   String      // Menghubungkan dengan `code` dari District
  district        District    @relation(fields: [district_code], references: [code]) // Menghubungkan ke District
  tailors         Tailor[]    @relation("VillageTailors") // Relasi dua arah ke Tailor
}

model Tailor {
  id                Int         @id @default(autoincrement())
  firstname         String      @db.VarChar(100)
  lastname          String?     @db.VarChar(100)
  email             String      @unique @db.VarChar(100)
  phoneNumber       String      @db.VarChar(20)
  password          String      @db.VarChar(100)
  provinceId        String      // Menghubungkan dengan `code` dari Province
  regencyId         String      // Menghubungkan dengan `code` dari Regency
  districtId        String      // Menghubungkan dengan `code` dari District
  villageId         String      // Menghubungkan dengan `code` dari Village
  addressDetail     String
  workEstimation    String
  priceRange        String
  specialization    String[]    // Array of string
  businessDescription String
  profilePicture    String?
  certificate       String[]
  ratingReviews     RatingReview[]
  averageRating     Float           @default(0.0)
  createdAt         DateTime    @default(now())
  token             String?     @db.VarChar(100)

  province          Province    @relation("ProvinceTailors", fields: [provinceId], references: [code])
  regency           Regency     @relation("RegencyTailors", fields: [regencyId], references: [code])
  district          District    @relation("DistrictTailors", fields: [districtId], references: [code])
  village           Village     @relation("VillageTailors", fields: [villageId], references: [code])
  roomsAsTailor     RoomChat[] @relation("TailorRooms")

  @@map("Tailor")
}


model RatingReview {
  id        Int      @id @default(autoincrement())
  rating    Int      @db.SmallInt   // Nilai dari 1-5
  review    String?   @db.VarChar(50)
  tailorId  Int      // Relasi ke Tailor
  customerId Int     // Relasi ke Customer
  tailor    Tailor   @relation(fields: [tailorId], references: [id])
  customer  Customer @relation(fields: [customerId], references: [id])
  createdAt DateTime @default(now())

  @@map("RatingReview")
}

model RoomChat {
  id         Int      @id @default(autoincrement())
  customerId Int
  tailorId   Int

  createdAt  DateTime @default(now())

  // Relasi ke Customer & Tailor
  customer   Customer @relation("CustomerRooms", fields: [customerId], references: [id])
  tailor     Tailor   @relation("TailorRooms", fields: [tailorId], references: [id])

  // Relasi ke Chat (banyak pesan)
  chats      Chat[]

  // Mencegah duplikasi room 1–1 (customerId, tailorId) sama
  @@unique([customerId, tailorId])
}

model Chat {
  id         Int      @id @default(autoincrement())
  roomId     Int
  room       RoomChat @relation(fields: [roomId], references: [id])

  senderId   Int
  senderType String   // "customer" or "tailor"
  message    String
  type       String   @default("text") // "text" or "image"
  createdAt  DateTime @default(now())
}
